<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <mapped-superclass name="Ivoz\Provider\Domain\Model\Webhook\WebhookAbstract" table="webhook_abstract">
    <field name="name" type="string" column="name" length="64" nullable="false">
      <options>
        <option name="fixed"/>
      </options>
    </field>
    <field name="description" type="string" column="description" length="255" nullable="true">
      <options>
        <option name="fixed"/>
      </options>
    </field>
    <field name="uri" type="text" column="URI" nullable="false"/>
    <field name="eventStart" type="boolean" column="eventStart" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="eventRing" type="boolean" column="eventRing" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="eventAnswer" type="boolean" column="eventAnswer" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="eventEnd" type="boolean" column="eventEnd" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="template" type="text" column="template" nullable="false"/>
    <many-to-one field="brand" target-entity="Ivoz\Provider\Domain\Model\Brand\BrandInterface" fetch="LAZY">
      <join-columns>
        <join-column name="brandId" referenced-column-name="id" on-delete="CASCADE" nullable="false"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="company" target-entity="Ivoz\Provider\Domain\Model\Company\CompanyInterface" fetch="LAZY">
      <join-columns>
        <join-column name="companyId" referenced-column-name="id" on-delete="CASCADE" nullable="true"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="ddi" target-entity="Ivoz\Provider\Domain\Model\Ddi\DdiInterface" fetch="LAZY">
      <join-columns>
        <join-column name="ddiId" referenced-column-name="id" on-delete="CASCADE" nullable="true"/>
      </join-columns>
    </many-to-one>
  </mapped-superclass>
</doctrine-mapping>